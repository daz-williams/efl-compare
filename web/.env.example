# EFL Comparator configuration. Copy this file to `.env` and edit.
# `.env` is git-ignored, so your local settings/secrets never get committed.
# Real environment variables take precedence over anything set here.

# ── LLM (OpenAI-compatible) ─────────────────────────────────────────────────
# The tool talks to an OpenAI-standard Chat Completions API, so it works with
# any compatible server — a local llama.cpp server, vLLM, Ollama, LM Studio, or
# the hosted OpenAI API — just by changing these values.

# Base URL of the API (must include the /v1 path for most servers).
EFL_LLM_BASE_URL=http://127.0.0.1:8080/v1

# Model id to request.
EFL_LLM_MODEL=qwen3.6-35b

# API key. Local servers usually ignore it — any placeholder is fine. For the
# hosted OpenAI API, put your real key here (and keep .env out of git).
EFL_LLM_API_KEY=sk-no-key-required

# Per-request timeout in seconds.
EFL_LLM_TIMEOUT=120

# Reasoning models (Qwen3, etc.) emit hidden "thinking" tokens that blow the
# small max_tokens budgets this tool uses. Set true to disable thinking.
# Sent as chat_template_kwargs.enable_thinking=false via the OpenAI extra_body.
# Harmless with non-reasoning models/servers that ignore it.
EFL_LLM_DISABLE_THINKING=true

# ── Search defaults (optional — can also be passed as CLI flags) ─────────────
# EFL_ZIP=75010
# EFL_TIERS=1200,1500,2000

# ── Cloudflare Tunnel (only needed for docker compose public hosting) ────────
CLOUDFLARE_TOKEN=your-cloudflare-tunnel-token-here
