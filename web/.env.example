# Copy to .env and fill in. .env is git-ignored (see .gitignore) so the token
# never reaches the upstream PR.
#
# This is the connector token for a remote-managed Cloudflare Tunnel. Create the
# tunnel in the Cloudflare Zero Trust dashboard (Networks -> Tunnels), copy its
# token, and configure a public hostname whose service points to:
#     http://web:8090
CLOUDFLARE_TOKEN=your-cloudflare-tunnel-token-here
